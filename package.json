{
  "name": "optrion",
  "version": "0.1.0",
  "description": "Track, score, quarantine, and clean orphaned options in your WordPress database.",
  "private": true,
  "license": "GPL-2.0-or-later",
  "scripts": {
    "env": "wp-env",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean all",
    "test": "wp-env run tests-cli --env-cwd=wp-content/plugins/optrion composer test",
    "lint": "wp-env run cli --env-cwd=wp-content/plugins/optrion composer lint",
    "lint:staged": "./vendor/bin/phpcs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@wordpress/env": "^10.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.php": [
      "./vendor/bin/phpcs"
    ]
  }
}
