#. Plugin Name of the plugin
#: orpharion.php includes/class-admin-page.php:48
#: includes/class-admin-page.php:49 includes/class-admin-page.php:96
msgid "Orpharion"
msgstr "Orpharion"

#. Plugin URI of the plugin
#: orpharion.php
msgid "https://github.com/mt8/orpharion"
msgstr "https://github.com/mt8/orpharion"

#. Description of the plugin
#: orpharion.php
msgid ""
"Track which plugin or theme accesses each wp_options row, then quarantine or "
"clean orphans."
msgstr ""
"各 wp_options 行にアクセスするプラグイン／テーマを追跡し、孤立したオプション"
"を検疫または削除します。"

#. Author of the plugin
#: orpharion.php
msgid "mt8biz"
msgstr "mt8biz"

