#: includes/class-cleaner.php
msgid "Could not create backup directory."
msgstr "バックアップディレクトリを作成できませんでした。"

#: includes/class-cleaner.php
msgid "Could not write backup file."
msgstr "バックアップファイルを書き出せませんでした。"

#: includes/class-cleaner.php
msgid "Failed to delete %s."
msgstr "%s の削除に失敗しました。"

#: includes/class-cleaner.php
msgid "Skipped core option: %s"
msgstr "コアオプションのためスキップしました: %s"

#: includes/class-quarantine.php
msgid "Could not delete the quarantined option row."
msgstr "検疫中オプションの本削除に失敗しました。"

#: includes/class-quarantine.php
msgid "Could not record the quarantine manifest."
msgstr "検疫マニフェストの記録に失敗しました。"

#: includes/class-quarantine.php
msgid "Could not rename the option row back."
msgstr "オプションの名前を元に戻せませんでした。"

#: includes/class-quarantine.php
msgid "Could not rename the option row."
msgstr "オプションのリネームに失敗しました。"

#: includes/class-quarantine.php
msgid "Option cannot be quarantined."
msgstr "このオプションは検疫できません。"

#: includes/class-quarantine.php
msgid "Option is already quarantined."
msgstr "既に検疫されています。"

#: includes/class-quarantine.php
msgid "Option name is empty."
msgstr "オプション名が空です。"

#: includes/class-quarantine.php
msgid "Option name is too long to safely quarantine."
msgstr "オプション名が長すぎるため、安全に検疫できません。"

#: includes/class-quarantine.php
msgid "Option not found in wp_options."
msgstr "wp_options にオプションが見つかりません。"

#: includes/class-quarantine.php
msgid "Quarantine entry is not active."
msgstr "検疫エントリは有効ではありません。"

#: includes/class-quarantine.php
msgid "Quarantine limit reached (%d active)."
msgstr "検疫の上限に達しました (有効件数: %d)。"

#: includes/class-quarantine.php
msgid "Quarantine manifest row not found."
msgstr "検疫マニフェストの行が見つかりません。"

#: includes/class-quarantine.php
msgid "WordPress core options cannot be quarantined."
msgstr "WordPress コアオプションは検疫できません。"

#: includes/class-importer.php
msgid "Entry missing option_name."
msgstr "option_name が欠落しているエントリです。"

#: includes/class-importer.php
msgid "Export payload has no options list."
msgstr "エクスポートデータに options リストがありません。"

#: includes/class-importer.php
msgid "Export payload is not valid JSON."
msgstr "エクスポートデータが有効な JSON ではありません。"

#: includes/class-importer.php
msgid "Failed to insert %s."
msgstr "%s の追加に失敗しました。"

#: includes/class-importer.php
msgid "Failed to overwrite %s."
msgstr "%s の上書きに失敗しました。"

#: includes/class-rest-controller.php
msgid "Option not found."
msgstr "オプションが見つかりません。"
